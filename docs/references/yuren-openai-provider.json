{
  "provider": {
    "yurenapi": {
      "name": "Yuren OpenAI",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "apiKey": "{env:YUREN_API_KEY}",
        "apiMode": "chat_completions",
        "baseURL": "https://yurenapi.cn/v1",
        "alternateBaseURLs": [
          "https://yurenapi.com/v1"
        ]
      },
      "models": {
        "gpt-5.4-mini": {
          "name": "GPT-5.4 Mini",
          "attachment": true,
          "reasoning": true,
          "limit": {
            "context": 400000,
            "input": 272000,
            "output": 128000
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          },
          "options": {
            "store": false
          },
          "variants": {
            "low": {
              "reasoningEffort": "low"
            },
            "medium": {
              "reasoningEffort": "medium"
            },
            "high": {
              "reasoningEffort": "high"
            },
            "xhigh": {
              "reasoningEffort": "xhigh"
            }
          }
        },
